local ObjectiveLabel = script.Parent:WaitForChild("CurrentObjectiveText")
local ChapterLabel = script.Parent:WaitForChild("ChapterTitleText")

Network.UpdateObjectiveHUD.OnClientEvent:Connect(function(chapterTitle, objectiveDescription)
	ChapterLabel.Text = string.upper(chapterTitle)
	ObjectiveLabel.Text = objectiveDescription
	
	-- Slick typewriter punch sound effect framing
	ObjectiveLabel.TextColor3 = Color3.fromRGB(255, 220, 0) -- Bold flash yellow tell
	task.wait(0.15)
	ObjectiveLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
end)
