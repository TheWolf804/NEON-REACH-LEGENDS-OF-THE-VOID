-- ReactorDoorScript (Server)
local terminal = script.Parent
local isLocked = true

function onTerminalActivated(player)
    local hasKey = player.KeyItems:FindFirstChild("MasterKey")
    
    if isLocked and hasKey then
        isLocked = false
        startUnlockCinematic(player)
    else
        -- Play a heavy "Rejected" buzzer sound
        playBuzzerSound()
        notifyPlayer(player, "AUTHENTICATION REQUIRED: LINK MASTER KEY")
    end
end

function startUnlockCinematic(player)
    -- 1. Freeze player for a dramatic moment
    player.Character.HumanoidRootPart.Anchored = true
    
    -- 2. The 3 Pylons light up one by one
    for i = 1, 3 do
        task.wait(1)
        local pylon = workspace.Antechamber["Pylon"..i]
        pylon.NeonPart.Color = Color3.fromRGB(0, 255, 255) -- Cyan Glow
        pylon.HumSound:Play()
    end
    
    -- 3. The Great Door opens
    task.wait(1.5)
    openReactorVault()
    
    -- 4. Substory Progress
    player.Character.HumanoidRootPart.Anchored = false
    notifyPlayer(player, "SUBSTORY UPDATE: The Path to the Architect is Open.")
end
