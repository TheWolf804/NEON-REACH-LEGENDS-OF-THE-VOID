-- ServerScriptService -> SubstoryProgressionManager
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Network = ReplicatedStorage:WaitForChild("NetworkEvents")

local SubstorySystem = {
	TotalStandardQuests = 432,
	SecretBossUnlocked = false
}

-- Triggered whenever a side quest finishes anywhere in the world
function OnSubstoryComplete(player, completedQuestId)
	local completedList = player:FindFirstChild("CompletedSubstories")
	if not completedList then
		completedList = Instance.new("Folder")
		completedList.Name = "CompletedSubstories"
		completedList.Parent = player
	end
	
	-- Mark this quest as complete securely
	if not completedList:FindFirstChild(tostring(completedQuestId)) then
		local questFlag = Instance.new("BoolValue")
		questFlag.Name = tostring(completedQuestId)
		questFlag.Value = true
		questFlag.Parent = completedList
	end
	
	-- Evaluate current progression tallies
	local completedCount = #completedList:GetChildren()
	
	-- Trigger standard UI celebratory banners
	Network.DisplaySubstoryClearCard:FireClient(player, completedQuestId, completedCount, SubstorySystem.TotalStandardQuests)
	
	-- CHECK FOR ULTIMATE UNLOCK: Did they hit exactly 432?
	if completedCount == SubstorySystem.TotalStandardQuests and not SubstorySystem.SecretBossUnlocked then
		SubstorySystem.SecretBossUnlocked = true
		TriggerSecretBossOverture(player)
	end
end

function TriggerSecretBossOverture(player)
	player:SetAttribute("AmonUnlocked", true)
	
	-- Dramatic classic framing: Force an ominous client side text transmission
	task.delay(5, function()
		Network.ReceiveMysteriousPagerText:FireClient(player, {
			Sender = "???",
			Message = "You have meddled in every corner of this city, Outmate. The slate must be wiped clean. Meet me at midnight on the absolute peak of the Area 2 Obsidian Plaza helipad. Do not keep me waiting."
		})
		
		-- Spawn the physical structural quest node in the world
		local bossTriggerNode = Instance.new("Part")
		bossTriggerNode.Name = "AmonTriggerNode"
		bossTriggerNode.Size = Vector3.new(8, 2, 8)
		bossTriggerNode.Position = Vector3.new(0, 450, 120) -- Way up on the sky helipad
		bossTriggerNode.Transparency = 0.5
		bossTriggerNode.Color = Color3.fromRGB(255, 0, 50)
		bossTriggerNode.CanCollide = false
		bossTriggerNode.Anchored = true
		
		local neonBeam = Instance.new("SelectionBox")
		neonBeam.Color3 = Color3.fromRGB(255, 0, 0)
		neonBeam.Adornee = bossTriggerNode
		neonBeam.Parent = bossTriggerNode
		
		bossTriggerNode.Parent = workspace.Environment.Area2_Plaza
		
		-- Set up the point-of-no-return interaction block
		bossTriggerNode.Touched:Connect(function(hit)
			local char = hit.Parent
			local p = game.Players:GetPlayerFromCharacter(char)
			if p == player and char:GetAttribute("InCinematicMode") ~= true then
				InitiateAmonBossFight(player, char, bossTriggerNode)
			end
		end)
	end)
end

function InitiateAmonBossFight(player, character, triggerNode)
	triggerNode:Destroy() -- Consume the trigger
	character:SetAttribute("InCinematicMode", true)
	character.Humanoid.WalkSpeed = 0
	
	-- Fire client cinematics: Sky turns completely red, dramatic title card sweeps in
	Network.TriggerAmonIntroCinematic:FireClient(player)
	Network.PlayZoneBGM:FireClient(player, "The_Sovereign_Of_Shadow_Amon")
	
	task.wait(4.0) -- Let the heavy industrial techno beat drop
	
	-- Spawn Shin Amon directly opposite the player
	local amon = ReplicatedStorage.Enemies.ShinAmonMaster:Clone()
	amon.PrimaryPart.CFrame = character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -35)
	amon.Parent = workspace.Enemies
	
	character:SetAttribute("InCinematicMode", false)
	character.Humanoid.WalkSpeed = 16
	
	-- Handle completion of Substory #433
	amon.Humanoid.Died:Connect(function()
		Network.PlayZoneBGM:FireClient(player, "Premium_Roaming_Funk")
		Network.DisplayLocationCard:FireClient(player, "SUBSTORY #433: SUBMIT TO SHADOW", "C L E A R")
		player:SetAttribute("EarnedUltimatePlatinumFlag", true)
		
		-- Reward: The Sacred Sunglasses (Gives global infinite Heat meter access)
		local rewards = player:FindFirstChild("ColiseumInventory")
		if rewards then
			local sunglasses = Instance.new("BoolValue", rewards)
			sunglasses.Name = "AmonSunglasses"
		end
	end)
end
