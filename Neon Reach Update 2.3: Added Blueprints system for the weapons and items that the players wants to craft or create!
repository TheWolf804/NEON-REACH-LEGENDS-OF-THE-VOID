-- Server Script: When player picks up a Data Chip
local function learnBlueprint(player, blueprintID)
	local playerData = player:WaitForChild("DataValues")
	local learnedList = playerData:WaitForChild("LearnedBlueprints")
	
	-- Check if already learned
	if not learnedList:FindFirstChild(blueprintID) then
		local newEntry = Instance.new("BoolValue")
		newEntry.Name = blueprintID
		newEntry.Parent = learnedList
		
		-- Trigger Yakuza-style UI Notification
		remoteEvents.NotifyBlueprint:FireClient(player, BlueprintDatabase[blueprintID].Name)
	end
end
