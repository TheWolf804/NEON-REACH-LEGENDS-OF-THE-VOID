-- ZenithSpireEncounter (Server Script)
local bridge = script.Parent
local remoteEvents = game.ReplicatedStorage:WaitForChild("NetworkEvents")
local bossSpawned = false

function onVanguardDefeated(player)
    if bossSpawned then return end
    bossSpawned = true
    
    -- 1. Initiating the Lockdown Sequence
    player.Character.HumanoidRootPart.Anchored = true
    remoteEvents.SetBridgeAmbiance:FireAllClients("BossPhase")
    
    -- 2. Heavy mechanical shifting sounds
    bridge.Sounds.ServerRetraction:Play()
    bridge.Sounds.PillarLock:Play()
    
    task.wait(3.0) -- Let the room completely flatten out
    
    -- 3. The Panoramic Reveal
    -- The massive blast shutters retract, revealing a massive collapsing star outside
    animateBlastShuttersOpen()
    bridge.Sounds.ShutterHiss:Play()
    
    task.wait(2.0)
    
    -- 4. Release player and begin the final dialogue trigger
    player.Character.HumanoidRootPart.Anchored = false
    triggerFinalBossIntro(player)
end
