-- ServerScriptService -> ShinAmonBossEngine
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Network = ReplicatedStorage:WaitForChild("NetworkEvents")

local AmonFight = {
	BossInstance = nil,
	TargetPlayer = nil,
	CurrentPhase = 1,
	IsExecutingSpecial = false
}

function AmonFight.Initialize(amonCharacter, player)
	AmonFight.BossInstance = amonCharacter
	AmonFight.TargetPlayer = player
	
	local hum = amonCharacter:WaitForChild("Humanoid")
	local root = amonCharacter:WaitForChild("HumanoidRootPart")
	
	hum.MaxHealth = 15000 -- Massive legendary raid boss health pool
	hum.Health = 15000
	
	-- Monitor health increments to transition smoothly between phases
	hum.HealthChanged:Connect(function(currentHealth)
		if AmonFight.CurrentPhase == 1 and currentHealth <= 7500 then
			AmonFight.CurrentPhase = 2
			task.spawn(AmonFight.TransitionToPhaseTwo)
		end
	end)
	
	-- Start Phase 1 Loop
	task.spawn(AmonFight.PhaseOneStanceMirrorLoop)
end

-----------------------------------------------------------------------
-- PHASE 1: THE MIRROR MATCH MATRIX
-----------------------------------------------------------------------
function AmonFight.PhaseOneStanceMirrorLoop()
	local hum = AmonFight.BossInstance:FindFirstChildOfClass("Humanoid")
	local root = AmonFight.BossInstance:FindFirstChild("HumanoidRootPart")
	
	while AmonFight.CurrentPhase == 1 and hum and hum.Health > 0 do
		local pChar = AmonFight.TargetPlayer.Character
		if pChar and pChar:FindFirstChild("HumanoidRootPart") then
			local pRoot = pChar.HumanoidRootPart
			local distance = (root.Position - pRoot.Position).Magnitude
			
			-- Mirror the player's active fighting style instantly
			local playerStyle = pChar:GetAttribute("CurrentStyle") or "Brawler"
			AmonFight.BossInstance:SetAttribute("CurrentStyle", playerStyle)
			
			if distance <= 8 and not AmonFight.IsExecutingSpecial then
				-- Defensive AI Counter Punish Rules
				if pChar:GetAttribute("IsAttacking") == true then
					AmonFight.IsExecutingSpecial = true
					
					if playerStyle == "Dragon" then
						-- The Ultimate Sin: Attempting to attack Amon while in Dragon Style
						Network.PlayEnemyAttackAnimation:FireAllClients(AmonFight.BossInstance, "AmonTigerDropCounter")
						Network.PlayBlockEffect:FireAllClients(root.Position, "AmonCounterSpark")
						
						pChar.Humanoid:TakeDamage(55) -- Punishing counter frames
						pChar:SetAttribute("StunState", "HardKnockdown")
						
						task.wait(1.5)
					else
						-- Standard defensive slip dodge response
						Network.PlayEnemyAttackAnimation:FireAllClients(AmonFight.BossInstance, "AmonRushWeave")
						root.CFrame = root.CFrame * CFrame.new(math.random(-5, 5), 0, -4)
						task.wait(0.5)
					end
					
					AmonFight.IsExecutingSpecial = false
				end
			end
		end
		task.wait(0.1)
	end
end

-----------------------------------------------------------------------
-- PHASE 2: TRIPLE-OVERDRIVE ORBITAL DRONE MATRIX
-----------------------------------------------------------------------
function AmonFight.TransitionToPhaseTwo()
	AmonFight.IsExecutingSpecial = true
	local root = AmonFight.BossInstance.HumanoidRootPart
	local hum = AmonFight.BossInstance.Humanoid
	
	-- Cinematic Mid-Fight Transition Frame
	AmonFight.TargetPlayer.Character.Humanoid.WalkSpeed = 0
	AmonFight.TargetPlayer.Character:SetAttribute("InCinematicMode", true)
	
	Network.DisplayLocationCard:FireClient(AmonFight.TargetPlayer, "PHASE 2: ORBITAL PROTOCOL", "Shin Amon: Sovereign of Shadow")
	Network.PlayElevatorAudioLoop:FireClient(AmonFight.TargetPlayer, "AmonRageScream")
	
	-- Hover into the sky over the helipad
	local bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.MaxForce = Vector3.new(0, 500000, 0)
	bodyVelocity.Velocity = Vector3.new(0, 20, 0)
	bodyVelocity.Parent = root
	
	-- Trigger the volatile glowing red plasma shield aura
	Network.ApplyAmonOverdriveVisual:FireAllClients(AmonFight.BossInstance, "CrimsonPlasmaShield")
	task.wait(2.0)
	bodyVelocity:Destroy()
	
	-- Return controls to player for the final bullet hell push
	AmonFight.TargetPlayer.Character.Humanoid.WalkSpeed = 16
	AmonFight.TargetPlayer.Character:SetAttribute("InCinematicMode", false)
	
	-- Run continuous Phase 2 hazard logic loop
	while AmonFight.CurrentPhase == 2 and hum and hum.Health > 0 do
		AmonFight.SpawnOrbitalDroneStrike()
		task.wait(1.8) -- Frequency of drone drop salvos
	end
end

function AmonFight.SpawnOrbitalDroneStrike()
	local pChar = AmonFight.TargetPlayer.Character
	if not pChar or not pChar:FindFirstChild("HumanoidRootPart") then return end
	local pRoot = pChar.HumanoidRootPart
	
	-- Predict player movement vector to punish blind kiting/running
	local targetPosition = pRoot.Position + (pRoot.AssemblyLinearVelocity * 0.4)
	
	-- Instantiate 3 distinct tactical laser drone nodes around the space
	for i = 1, 3 do
		task.spawn(function()
			local offset = Vector3.new(math.random(-12, 12), 40, math.random(-12, 12))
			local dronePos = targetPosition + offset
			
			-- Cast warning indicator beam directly down onto the asphalt pavement grid
			local raycastResult = workspace:Raycast(dronePos, Vector3.new(0, -60, 0))
			if raycastResult then
				local hitPos = raycastResult.Position
				Network.CreateHolographicTargetAoE:FireAllClients(hitPos, 6) -- 6-stud hazard ring
				
				task.wait(0.8) -- Precise window provided to quick-step or dash clear
				
				-- Fire the down-pointing tactical energy beam
				Network.PlayBreakEffect:FireAllClients(hitPos, "OrbitalLaserDetonator")
				Network.PlayCameraShakeGlobal:FireAllClients(2, 10)
				
				-- Check dynamic damage boundaries on verification
				if pChar and pChar:FindFirstChild("HumanoidRootPart") then
					local distance = (pChar.HumanoidRootPart.Position - hitPos).Magnitude
					if distance <= 6 then
						-- The laser tears directly past blocking armor frames entirely
						pChar.Humanoid:TakeDamage(25)
						pChar:SetAttribute("StunState", "Stagger")
					end
				end
			end
		end)
	end
end

-- Hook global workspace listener execution framework securely
workspace.Enemies.ChildAdded:Connect(function(child)
	if child.Name == "ShinAmonMaster" then
		-- Automatically map player context targeting parameters
		local player = game.Players:GetPlayers()[1] -- Snags the single master lobby host
		if player then
			AmonFight.Initialize(child, player)
		end
	end
end)
